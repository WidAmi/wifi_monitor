[Unit]
Description=Collect WiFi and wired port stats from Orbi APs into InfluxDB
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=INSTALL_DIR/.env
ExecStart=INSTALL_DIR/venv/bin/python INSTALL_DIR/collector/collect.py
StandardOutput=journal
StandardError=journal
