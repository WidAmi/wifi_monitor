{
  "title": "Client Detail",
  "uid": "client-detail",
  "description": "Per-client signal strength and throughput",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "graphTooltip": 1,
  "tags": ["network", "wifi"],

  "templating": {
    "list": [
      {
        "name": "client_mac",
        "label": "Client",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"netstats\", tag: \"mac\", predicate: (r) => r._measurement == \"wifi_station\")",
        "refresh": 2,
        "hide": 0,
        "multi": false,
        "includeAll": false,
        "sort": 1
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "title": "Signal Strength",
      "description": "Series label shows which AP and band the client is associated to. A new series appears on roam.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": 300000 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -80 },
              { "color": "yellow", "value": -70 },
              { "color": "green", "value": -60 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"netstats\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wifi_station\" and r.mac == \"${client_mac}\")\n  |> filter(fn: (r) => r._field == \"signal_dbm\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: true)\n  |> map(fn: (r) => ({r with _field: r.ap + \" \" + r.band}))"
        }
      ]
    },

    {
      "id": 2,
      "title": "Throughput",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 10 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": 300000 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "tx.*" },
            "properties": [{ "id": "custom.transform", "value": "negative-Y" }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"netstats\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wifi_station\" and r.mac == \"${client_mac}\")\n  |> filter(fn: (r) => r._field == \"tx_bytes\" or r._field == \"rx_bytes\")\n  |> derivative(unit: 1s, nonNegative: true)\n  |> map(fn: (r) => ({r with _value: r._value * 8.0}))\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: true)\n  |> map(fn: (r) => ({r with _field: if r._field == \"tx_bytes\" then \"tx\" else \"rx\"}))"
        }
      ]
    }

  ]
}
